# Copy this file to `.env` (repo root). It is gitignored.
#
# The app auto-loads `.env` when starting `rag` or `rag-tui`.

# -------------------------
# Core behavior
# -------------------------
# RAG_LLM_BACKEND=local            # local | openai | cerebras | ollama
# RAG_MEMORY_MODE=session          # off | session | persist
# RAG_ENABLE_WEB=0                 # 0/1 (enables SEARCH:/WEB: tools)
# RAG_DEVICE=cpu
# OMP_NUM_THREADS=1

# Optional: skill/instructions file
# RAG_SKILL_FILE=skill.asc

# -------------------------
# Embeddings (SentenceTransformer)
# -------------------------
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# USE_FAISS=1

# -------------------------
# OpenAI (GPT-5.3)
# -------------------------
# RAG_LLM_BACKEND=openai
# OPENAI_API_KEY=your_key_here
# OPENAI_MODEL=gpt-5.3-chat-latest

# -------------------------
# Cerebras (OpenAI-compatible API)
# -------------------------
# RAG_LLM_BACKEND=cerebras
# CEREBRAS_API_KEY=your_key_here
# CEREBRAS_MODEL=llama3.1-8b
# CEREBRAS_MODELS=llama3.1-8b,qwen-3-235b-a22b-instruct-2507
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# -------------------------
# Ollama (local server)
# -------------------------
# RAG_LLM_BACKEND=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# -------------------------
# Optional APIs for data collector
# -------------------------
# TMDB_API_KEY=...
# NASA_API_KEY=...

